# SIG-FDSU RDC — configuration locale (copier vers .env)
# cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# Les variables d'environnement du shell priment sur ce fichier.
# Si .env est absent, les valeurs par défaut de app/config.py s'appliquent.

# --- PostgreSQL / PostGIS ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sig_fdsu_rdc
DB_USER=postgres
DB_PASSWORD=test123
DATABASE_URL=postgresql://postgres:test123@localhost:5432/sig_fdsu_rdc

# --- Mode de données API ---
# json : mode démonstration / fallback JSON local (data/reports) — défaut sans PostgreSQL
# db   : mode PostgreSQL/PostGIS — active la lecture/écriture via la base
DATA_MODE=db
