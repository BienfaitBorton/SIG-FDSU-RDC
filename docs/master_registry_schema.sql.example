-- Référentiel National des Actifs FDSU — schéma master.*
-- Fichier d'exemple versionnable (*.sql est gitignoré dans ce dépôt).
-- Source de vérité métier : data/raw/FDSU Structure code Territoire zones.xlsx

CREATE SCHEMA IF NOT EXISTS master;

CREATE TABLE IF NOT EXISTS master.entities (
    uuid                UUID PRIMARY KEY,
    business_id         TEXT NOT NULL,
    entity_type         TEXT NOT NULL,
    name                TEXT NOT NULL,
    status              TEXT NOT NULL DEFAULT 'draft',
    validation_status   TEXT NOT NULL DEFAULT 'pending',
    confidence_level    TEXT NOT NULL DEFAULT 'unknown',
    source              TEXT,
    version             INTEGER NOT NULL DEFAULT 1,
    attributes          JSONB NOT NULL DEFAULT '{}'::jsonb,
    geometry            geometry(Geometry, 4326),
    merged_into         UUID NULL REFERENCES master.entities(uuid),
    created_at          TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at          TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_master_entities_business_id UNIQUE (business_id),
    CONSTRAINT chk_master_entity_type CHECK (entity_type <> ''),
    CONSTRAINT chk_master_site_not_artificial CHECK (
        entity_type <> 'SITE'
        OR business_id ~ '^FDSU_[A-Z]{2}_[0-9]{2}_[0-9]{3}(_[0-9]{3})?_[0-9]{3,5}$'
    )
);

CREATE INDEX IF NOT EXISTS idx_master_entities_type ON master.entities (entity_type);
CREATE INDEX IF NOT EXISTS idx_master_entities_status ON master.entities (status);
CREATE INDEX IF NOT EXISTS idx_master_entities_validation ON master.entities (validation_status);
CREATE INDEX IF NOT EXISTS idx_master_entities_source ON master.entities (source);
CREATE INDEX IF NOT EXISTS idx_master_entities_geom ON master.entities USING GIST (geometry);
CREATE INDEX IF NOT EXISTS idx_master_entities_attributes ON master.entities USING GIN (attributes);

CREATE TABLE IF NOT EXISTS master.entity_versions (
    id              BIGSERIAL PRIMARY KEY,
    entity_uuid     UUID NOT NULL REFERENCES master.entities(uuid) ON DELETE CASCADE,
    version         INTEGER NOT NULL,
    change_type     TEXT NOT NULL,
    note            TEXT,
    snapshot        JSONB NOT NULL DEFAULT '{}'::jsonb,
    changed_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_master_entity_versions_entity
    ON master.entity_versions (entity_uuid, version);

CREATE TABLE IF NOT EXISTS master.entity_aliases (
    id              BIGSERIAL PRIMARY KEY,
    entity_uuid     UUID NOT NULL REFERENCES master.entities(uuid) ON DELETE CASCADE,
    alias           TEXT NOT NULL,
    alias_type      TEXT NOT NULL DEFAULT 'alternate',
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_master_alias UNIQUE (alias)
);

CREATE TABLE IF NOT EXISTS master.entity_sources (
    id                  BIGSERIAL PRIMARY KEY,
    code                TEXT NOT NULL UNIQUE,
    label               TEXT NOT NULL,
    path                TEXT,
    imported_at         TIMESTAMPTZ,
    confidence_level    TEXT DEFAULT 'medium',
    metadata            JSONB NOT NULL DEFAULT '{}'::jsonb,
    created_at          TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS master.entity_links (
    id              BIGSERIAL PRIMARY KEY,
    from_uuid       UUID NOT NULL REFERENCES master.entities(uuid) ON DELETE CASCADE,
    to_uuid         UUID NOT NULL REFERENCES master.entities(uuid) ON DELETE CASCADE,
    link_type       TEXT NOT NULL,
    note            TEXT,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_master_entity_links_from ON master.entity_links (from_uuid);
CREATE INDEX IF NOT EXISTS idx_master_entity_links_to ON master.entity_links (to_uuid);

CREATE TABLE IF NOT EXISTS master.validation_log (
    id              BIGSERIAL PRIMARY KEY,
    entity_uuid     UUID REFERENCES master.entities(uuid) ON DELETE SET NULL,
    validated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    result          JSONB NOT NULL DEFAULT '{}'::jsonb
);

COMMENT ON SCHEMA master IS 'Référentiel National des Actifs FDSU — source officielle de vérité';
COMMENT ON TABLE master.entities IS 'Entités métier FDSU ; business_id site = code FDSU officiel';
COMMENT ON COLUMN master.entities.business_id IS 'Pour SITE : FDSU_ND_18_003_10100 (jamais SITE-FDSU-000001)';
